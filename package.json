{
  "name": "fathom-whiteboard",
  "version": "0.1.7",
  "description": "Generate explanatory whiteboards from research papers using Claude + excalidraw-mcp + the coleam00 diagram SKILL.",
  "license": "MIT",
  "author": "Ashrya <ashryaagr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashryaagr/fathom-whiteboard.git"
  },
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "scripts/build-vendor.mjs",
    "src/SKILL.md",
    "vendor/excalidraw-mcp/dist/**",
    "vendor/excalidraw-mcp/package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "postinstall": "node scripts/build-vendor.mjs",
    "app:build": "node app/build.mjs",
    "app": "npm run app:build && electron app/dist/main.js",
    "app:dev": "npm run app:build && WB_DEVTOOLS=1 electron app/dist/main.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@excalidraw/excalidraw": "^0.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "^41.3.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
